# MLB HR Predictor - Environment Variables

# Optional: The Odds API (https://the-odds-api.com) - free tier available
# Used for implied probability from betting markets
MLB_ODDS_API_KEY=your_odds_api_key_here

# Scheduler times (24h format, local machine time)
PREDICT_TIME=09:00
RESULTS_TIME=23:30

# Dashboard settings
DASH_HOST=0.0.0.0
DASH_PORT=8050
DASH_DEBUG=False

# Data cache directory (default: data/)
DATA_CACHE_DIR=data

# Model output directory (default: models/)
MODEL_DIR=models

# Training data years (inclusive)
TRAIN_START_YEAR=2017
TRAIN_END_YEAR=2025

# Prediction confidence threshold (HR probability %)
HIGH_CONFIDENCE_THRESHOLD=0.18
MEDIUM_CONFIDENCE_THRESHOLD=0.12
